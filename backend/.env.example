PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
SOLANA_RPC=https://api.devnet.solana.com
CORS_ORIGINS=http://localhost:5173
# SPL mints for checkout (set per cluster — mainnet USDT: Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB)
USDT_MINT_ADDRESS=
USDC_MINT_ADDRESS=
AUDD_MINT_ADDRESS=
PUSD_MINT_ADDRESS=

# IPFS: local Kubo (dev) OR Pinata on Vercel / production
# IPFS_API_HOST=127.0.0.1
# IPFS_API_PORT=5001
# IPFS_API_PROTOCOL=http
# IPFS_GATEWAY_URL=http://127.0.0.1:8081/ipfs
# IPFS_GATEWAY_FALLBACK_URL=https://ipfs.io/ipfs

# Pinata (recommended for Vercel — no local IPFS node)
# Create JWT at https://app.pinata.cloud/keys
# PINATA_JWT=
# Or legacy keys:
# PINATA_API_KEY=
# PINATA_API_SECRET=
